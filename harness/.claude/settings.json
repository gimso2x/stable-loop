{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(npm test*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(mkdir*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(node *)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -r /)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)",
      "Bash(git push --force*)",
      "Bash(git branch -D*)",
      "Bash(DROP *)",
      "Bash(npm publish*)"
    ]
  }
}
